# VeruView environment variables
# Copy this file to server/.env for local development
# Add each variable to the Vercel dashboard for production

# PostgreSQL connection string
# Local:   postgresql://postgres:postgres@localhost:5432/veruview
# Vercel:  provided automatically when you link Vercel Postgres
DATABASE_URL=

# Express session secret — use a long random string in production
SESSION_SECRET=

# Google OAuth2 credentials (optional — skip to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Callback URL registered in Google Cloud Console
# Local:      http://localhost:3001/api/auth/google/callback
# Production: https://your-app.vercel.app/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# URL of the frontend — used for CORS and OAuth redirects
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=

# Server port (local dev only — Vercel sets this automatically)
PORT=3001
